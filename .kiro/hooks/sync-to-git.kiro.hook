{
  "enabled": true,
  "name": "Sync to Git",
  "description": "Commits all changes and pushes to git repository when prompted",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git commit -m \"Auto-sync: $(date '+%Y-%m-%d %H:%M:%S')\" && git push"
  }
}