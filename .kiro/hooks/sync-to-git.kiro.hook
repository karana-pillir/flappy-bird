{
  "enabled": true,
  "name": "Sync to Git",
  "description": "Commits all changes and pushes to git repository when prompted",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "git add . && git commit -m \"Auto-sync\" && git branch -M main && git remote add origin https://github.com/karana-pillir/flappy-bird.git && git push -u origin main"
  },
  "workspaceFolderName": "kiro-introduction",
  "shortName": "sync-to-git"
}